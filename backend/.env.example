PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Example: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/supermarket?retryWrites=true&w=majority
MONGODB_URI=

# Required for JWT auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend URL (password reset emails)
FRONTEND_URL=http://localhost:5173

# Email (SMTP — used for forgot password, enquiry replies, job notifications)
# Gmail: enable 2-Step Verification, create App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Optional — defaults to SMTP_USER when empty
SMTP_FROM=
# Optional — defaults to SMTP_USER; used for admin job/enquiry notifications
ADMIN_EMAIL=
# Optional — sender display name in emails
STORE_NAME=Wins Wereld Winkel

# Local File Storage (All uploads are stored locally on the server in backend/src/uploads)
# Express serves files statically at /uploads/ and Nginx should proxy /uploads/ to the backend port.

