PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (required on Railway)
# Example: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/supermarket?retryWrites=true&w=majority
MONGODB_URI=

# Required for JWT auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://wins-wereld-winkel.netlify.app

# Frontend URL (password reset emails)
FRONTEND_URL=http://localhost:5173

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_EMAIL=
STORE_NAME=Wins Wereld Winkel

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
